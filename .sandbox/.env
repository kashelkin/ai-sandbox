# Base image for the sandbox container.
# Must be a Debian/Ubuntu-based devcontainer image — the Dockerfile assumes
# sudo removal, apt tooling, and a home directory at /home/${CONTAINER_USER}.
# Examples:
#   mcr.microsoft.com/devcontainers/dotnet:10.0-noble  (default, .NET 10)
#   mcr.microsoft.com/devcontainers/dotnet:8.0-noble   (.NET 8 LTS)
#   mcr.microsoft.com/devcontainers/base:noble          (no SDK)
SANDBOX_IMAGE=mcr.microsoft.com/devcontainers/dotnet:10.0-noble

CONTAINER_USER=vscode

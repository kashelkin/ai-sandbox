# Base image for the sandbox container.
# Must be a Debian/Ubuntu-based devcontainer image — the init scripts require
# apt tooling and a home directory at /home/${CONTAINER_USER}.
# To use a different base image, update init-root.sh accordingly.
# Examples:
#   mcr.microsoft.com/devcontainers/dotnet:10.0-noble  (default, .NET 10)
#   mcr.microsoft.com/devcontainers/dotnet:8.0-noble   (.NET 8 LTS)
#   mcr.microsoft.com/devcontainers/base:noble          (no SDK)
SANDBOX_IMAGE=mcr.microsoft.com/devcontainers/dotnet:10.0-noble

CONTAINER_USER=vscode

# Project name used as the Docker Compose project name, which prefixes all
# container, network, and volume names. Change this when running multiple
# sandbox instances to keep their Docker resources isolated from each other.
PROJECT_NAME=ai-sandbox
